# Skills Hub 开发/构建环境配置
# 用于 docker-compose-dev.yml 和 docker-compose-build.yml
# 连接云端服务器 (115.190.114.160) 的外部服务

# ==================== 镜像配置 ====================
IMAGE_TAG=dev-latest

# ==================== 服务配置 ====================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
RUN_MODE=dev
RUST_LOG=debug

# ==================== 数据库配置 ====================
# 连接云端 PostgreSQL
DATABASE_URL=postgres://skillhub:3laQ20iiy7ZhHLMoyx3B@115.190.114.160:5432/skillhub
MAX_DB_CONNECTIONS=5

# ==================== Redis 配置 ====================
# 连接云端 Redis
REDIS_URL=redis://115.190.114.160:6379

# ==================== JWT 配置 ====================
JWT_SECRET=Rgh4sppdKRDTOB0xC30ndqjkKb3vnaO5zO59QtV2zXwkPfPPJ5ZTzDGNNEBXwC
JWT_EXPIRATION_HOURS=24

# ==================== 存储配置 ====================
# 连接云端 MinIO
STORAGE_TYPE=minio
STORAGE_ENDPOINT=http://115.190.114.160:9000
